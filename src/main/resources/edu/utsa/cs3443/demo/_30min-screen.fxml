<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane maxHeight="-Infinity"
      stylesheets="@styles/Horizon.css"
      styleClass="multi-theme"
      maxWidth="-Infinity" minHeight="-Infinity"
      minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.utsa.cs3443.demo._30minController">
   <children>
      <Label fx:id="timerLabel" layoutX="257.0" layoutY="114.0" text="Label">
         <font>
            <Font size="36.0" />
         </font>
      </Label>
      <Button fx:id="startButton" layoutX="206.0" layoutY="175.0" mnemonicParsing="false" onAction="#startOnClick" text="Start">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button fx:id="pauseButton" layoutX="327.0" layoutY="175.0" mnemonicParsing="false" onAction="#pauseOnClick" text="Pause">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button fx:id="backButton" layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backOnClick" prefHeight="25.0" prefWidth="49.0" text="Back">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Label fx:id="completeLabel" layoutX="230.0" layoutY="222.0" prefHeight="17.0" prefWidth="155.0" text="Study Session Complete!" textFill="#19c93f" visible="false" />
      <Label fx:id="topicLabel" layoutX="161.0" layoutY="50.0" prefHeight="23.0" prefWidth="390.0" text="Label">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
   </children>
</Pane>
