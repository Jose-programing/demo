<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="400.0" prefWidth="600.0"
      stylesheets="@styles/Horizon.css"
      styleClass="multi-theme"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.utsa.cs3443.demo.customScreenController">

   <children>

      <!-- Title -->
      <Label layoutX="178.0" layoutY="87.0"
             text="Enter topic information:"
             styleClass="title-label">
         <font>
            <Font size="24.0" />
         </font>
      </Label>

      <!-- Topic Name -->
      <TextField fx:id="topicName"
                 layoutX="193.0" layoutY="133.0"
                 promptText="Enter topic name:"
                 styleClass="info-label">
         <font>
            <Font size="16.0" />
         </font>
      </TextField>

      <!-- Session Goal -->
      <TextField fx:id="sessionGoal"
                 layoutX="193.0" layoutY="185.0"
                 promptText="Enter session goal:"
                 styleClass="info-label">
         <font>
            <Font size="16.0" />
         </font>
      </TextField>

      <!-- Submit Button -->
      <Button fx:id="sumbit"
              layoutX="254.0" layoutY="247.0"
              text="Submit"
              onAction="#sumbitOnClick"
              styleClass="button">
         <font>
            <Font size="16.0" />
         </font>
      </Button>

      <!-- Back Button -->
      <Button fx:id="back"
              layoutX="19.0" layoutY="18.0"
              text="Back"
              onAction="#backOnClick"
              styleClass="button">
         <font>
            <Font size="15.0" />
         </font>
      </Button>

      <!-- Error Label -->
      <Label fx:id="errorLabel"
             layoutX="206.0" layoutY="287.0"
             prefWidth="180.0"
             text="Label"
             textFill="#d03737"
             visible="false"
             styleClass="section-label" />

   </children>
</Pane>
