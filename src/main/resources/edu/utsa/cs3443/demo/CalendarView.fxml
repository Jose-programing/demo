<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="156.0" prefWidth="471.0" spacing="12" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.utsa.cs3443.demo.CalendarController">

    <padding>
        <Insets bottom="16" left="16" right="16" top="16" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Month:" />
        <ComboBox fx:id="monthCombo" onAction="#onDropdownChange" />
        <Label text="Year:" />
        <ComboBox fx:id="yearCombo" onAction="#onDropdownChange" />
    </HBox>

    <GridPane fx:id="dayGrid" hgap="6" vgap="6">
        <columnConstraints>
            <ColumnConstraints percentWidth="14.28" />
            <ColumnConstraints percentWidth="14.28" />
            <ColumnConstraints percentWidth="14.28" />
            <ColumnConstraints percentWidth="14.28" />
            <ColumnConstraints percentWidth="14.28" />
            <ColumnConstraints percentWidth="14.28" />
            <ColumnConstraints percentWidth="14.28" />
        </columnConstraints>

        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold;" text="Mon" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold;" text="Tue" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold;" text="Wed" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold;" text="Thu" GridPane.columnIndex="3" GridPane.rowIndex="0" />
        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold;" text="Fri" GridPane.columnIndex="4" GridPane.rowIndex="0" />
        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold;" text="Sat" GridPane.columnIndex="5" GridPane.rowIndex="0" />
        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold;" text="Sun" GridPane.columnIndex="6" GridPane.rowIndex="0" />
      <rowConstraints>
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="selectedDateLabel" text="No date selected" />
        <Button onAction="#onViewDayClicked" text="View Day" />
      <Label text="Return to Main Menu" />
      <Button fx:id="backButtonLabel" mnemonicParsing="false" onAction="#onBackClicked" text="Back" />
    </HBox>

</VBox>
