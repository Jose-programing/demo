<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="multi-theme" stylesheets="@styles/Horizon.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.utsa.cs3443.demo.MainMenuController">

    <!-- LEFT NAVIGATION MENU -->
    <VBox spacing="20" AnchorPane.leftAnchor="40" AnchorPane.topAnchor="80">

        <Button fx:id="calendarButton" onAction="#onCalendar" prefHeight="40" prefWidth="180" text="CALENDAR" />

        <Button fx:id="crudButton" onAction="#onCrud" prefHeight="40" prefWidth="180" text="Tasks" />

        <Button fx:id="studyButton" onAction="#onStudySession" prefHeight="40" prefWidth="180" text="STUDY SESSION" />

    </VBox>

    <!-- MAIN CONTENT AREA -->
    <VBox spacing="20" AnchorPane.leftAnchor="260" AnchorPane.topAnchor="80">

        <Label styleClass="title-label" text="WELCOME STUDENT" />

        <Label styleClass="section-label" text="Due Today:" />

        <VBox fx:id="taskListBox" spacing="10" style="-fx-font-family: monospace;" />

        <Separator prefWidth="600" />

        <Label styleClass="section-label" text="Study Session:" />
        <Label fx:id="studySessionLabel" styleClass="info-label" text="No study session set." />

        <Label styleClass="section-label" text="Priority Level:" />
        <Label fx:id="priorityLabel" styleClass="info-label" text="None" />

        <Separator prefWidth="600" />

        <Label fx:id="quoteLabel" styleClass="quote-label" text="Press the button to generate a quote." wrapText="true" />

        <Button fx:id="quoteButton" onAction="#onGenerateQuote" prefHeight="40" prefWidth="180" text="Generate Quote" />

    </VBox>

    <!-- LOGOUT BUTTON (BOTTOM RIGHT) -->
    <Button fx:id="backButton" onAction="#onBack" prefHeight="35" prefWidth="120" text="LOG OUT" AnchorPane.bottomAnchor="20" AnchorPane.rightAnchor="20" />

</AnchorPane>
