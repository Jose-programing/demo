<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1500.0" styleClass="multi-theme" stylesheets="@styles/Horizon.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.utsa.cs3443.demo.UpdateController">
   <children>
      <Label alignment="CENTER" layoutX="625.0" layoutY="36.0" prefHeight="150.0" prefWidth="250.0" style="-fx-background-radius: 30;" styleClass="red-theme" text="Update">
         <font>
            <Font name="System Bold" size="36.0" />
         </font>
      </Label>
      <Button fx:id="returnButton" layoutX="39.0" layoutY="41.0" mnemonicParsing="false" onAction="#goToCRUD" prefHeight="70.0" prefWidth="200.0" style="-fx-background-radius: 30;" text="Return">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button fx:id="UpdateTask" layoutX="650.0" layoutY="654.0" mnemonicParsing="false" onAction="#FinalUpdateButton" prefHeight="70.0" prefWidth="200.0" style="-fx-background-radius: 30;" text="UPDATE TASK">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <TextField fx:id="titleField" alignment="CENTER" layoutX="664.0" layoutY="264.0" prefHeight="70.0" prefWidth="172.0" promptText="Title">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </TextField>
      <TextField fx:id="typeField" alignment="CENTER" layoutX="664.0" layoutY="378.0" prefHeight="70.0" prefWidth="172.0" promptText="Task Type">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </TextField>
      <TextField fx:id="timeField" alignment="CENTER" layoutX="664.0" layoutY="484.0" prefHeight="70.0" prefWidth="172.0" promptText="Time">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </TextField>
   </children>
</AnchorPane>
