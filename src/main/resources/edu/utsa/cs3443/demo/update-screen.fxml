<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0"
            prefWidth="1500.0"
            stylesheets="@styles/Horizon.css"
            styleClass="multi-theme"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.utsa.cs3443.demo.UpdateController">
   <children>
      <Label alignment="CENTER" layoutX="667.0" layoutY="59.0" prefHeight="150.0" prefWidth="250.0" style="-fx-background-color: grey;" text="Update">
         <font>
            <Font size="36.0" />
         </font>
      </Label>
      <Button fx:id="returnButton" layoutX="39.0" layoutY="41.0" mnemonicParsing="false" onAction="#goToCRUD" prefHeight="70.0" prefWidth="200.0" text="Return">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <TextField fx:id="titleField" layoutX="562.0" layoutY="316.0" prefHeight="70.0" prefWidth="172.0" />
      <TextField fx:id="typeField" layoutX="876.0" layoutY="316.0" prefHeight="70.0" prefWidth="172.0" />
      <TextField fx:id="timeField" layoutX="876.0" layoutY="503.0" prefHeight="70.0" prefWidth="172.0" />
      <Button fx:id="UpdateTask" layoutX="705.0" layoutY="651.0" mnemonicParsing="false" onAction="#FinalUpdateButton" prefHeight="70.0" prefWidth="200.0" text="UPDATE TASK">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Label layoutX="562.0" layoutY="283.0" prefHeight="34.0" prefWidth="93.0" text="Task Title: ">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="876.0" layoutY="283.0" prefHeight="34.0" prefWidth="93.0" text="Task Type: ">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="562.0" layoutY="468.0" prefHeight="34.0" prefWidth="93.0" text="Priority: ">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="876.0" layoutY="468.0" prefHeight="34.0" prefWidth="93.0" text="Time: ">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="priorityField" layoutX="562.0" layoutY="503.0" prefHeight="70.0" prefWidth="172.0" />
   </children>
</AnchorPane>
