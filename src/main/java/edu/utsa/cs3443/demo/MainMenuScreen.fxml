<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.utsa.cs3443.demo.MainMenuController"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #f4f6f9;">

    <!-- LEFT NAVIGATION MENU (styled like Raise The Bar) -->
    <VBox spacing="20"
          AnchorPane.topAnchor="80"
          AnchorPane.leftAnchor="40">

        <Button fx:id="calendarButton"
                text="CALENDAR"
                prefWidth="180" prefHeight="40"
                style="-fx-background-radius: 0; -fx-background-color: #f3f3f3;
                       -fx-border-color: #cccccc; -fx-font-size: 14px;"
                onAction="#onCalendar"/>

        <Button fx:id="crudButton"
                text="CRUD"
                prefWidth="180" prefHeight="40"
                style="-fx-background-radius: 0; -fx-background-color: #f3f3f3;
                       -fx-border-color: #cccccc; -fx-font-size: 14px;"
                onAction="#onCrud"/>

        <Button fx:id="studyButton"
                text="STUDY SESSION"
                prefWidth="180" prefHeight="40"
                style="-fx-background-radius: 0; -fx-background-color: #f3f3f3;
                       -fx-border-color: #cccccc; -fx-font-size: 14px;"
                onAction="#onStudySession"/>

    </VBox>

    <!-- LOGOUT BUTTON (BOTTOM RIGHT) -->
    <Button fx:id="backButton"
            text="LOG OUT"
            onAction="#onBack"
            prefWidth="120" prefHeight="35"
            style="-fx-background-color: #e63333; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-background-radius: 3;"
            AnchorPane.bottomAnchor="20"
            AnchorPane.rightAnchor="20"/>

    <!-- MAIN CONTENT AREA -->
    <VBox spacing="20"
          AnchorPane.topAnchor="80"
          AnchorPane.leftAnchor="260">

        <Label text="WELCOME STUDENT"
               style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

        <Label text="Due Today:"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <VBox fx:id="taskListBox" spacing="10"/>

        <Separator prefWidth="600"/>

        <Label text="Study Session:"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label fx:id="studySessionLabel"
               text="No study session set."
               style="-fx-font-size: 16px;"/>

        <Label text="Priority Level:"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label fx:id="priorityLabel"
               text="None"
               style="-fx-font-size: 16px;"/>

        <Separator prefWidth="600"/>

        <Label fx:id="quoteLabel"
               text="Press the button to generate a quote."
               wrapText="true"
               style="-fx-font-size: 18px; -fx-font-style: italic;"/>

        <Button fx:id="quoteButton"
                text="Generate Quote"
                prefWidth="180" prefHeight="40"
                style="-fx-background-radius: 0; -fx-background-color: #f3f3f3;
                       -fx-border-color: #cccccc; -fx-font-size: 14px;"
                onAction="#onGenerateQuote"/>

    </VBox>

</AnchorPane>
